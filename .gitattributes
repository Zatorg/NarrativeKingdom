# ── Default: normalize line endings to LF in the repo ────────────────────────
* text=auto eol=lf

# ── Web / source files: always LF ────────────────────────────────────────────
*.mjs   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.hbs   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf

